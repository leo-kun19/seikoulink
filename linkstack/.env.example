PORT=3500
JWT_SECRET=your_random_jwt_secret_here
DOMAIN=your.domain.com
NODE_ENV=production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=SeikouLink <noreply@your.domain.com>

# Optional: Google Safe Browsing API (untuk deteksi phishing/malware real-time)
# Get key: https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com
# SAFE_BROWSING_API_KEY=

# Optional: Google OAuth (Login with Google)
# Setup: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your.domain.com/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
